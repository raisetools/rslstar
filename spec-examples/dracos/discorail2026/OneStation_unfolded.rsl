scheme OneStation_unfolded = class
type
Route = array RouteIndex of SegmentID,

Switchboxes = array RouteIndex of SwitchboxID,

TNextSbReservation = array TwoIndex of SegmentID,

RouteIndex = {| i : Int :- (i >= 0) /\ (i < 4) |},

RouteIndexFromOne = {| i : Int :- (i >= 1) /\ (i < 4) |},

RouteIndexOneLess = {| i : Int :- (i >= 1) /\ (i < 3) |},

TwoIndex = {| i : Int :- (i >= 0) /\ (i < 2) |},

SbReservation = array SbIndex of TrainID,

SbSegments = array SbIndex of SegmentID,

Connection = array TwoIndex of SegmentID,

SensorState == active | passive,

SbIndex = {| i : Int :- (i >= 0) /\ (i < 3) |},

SegmentID_prime = {| s : SegmentID :- s ~= seg_none |},

SegmentID == s1 | s2 | s3 | s4 | seg_none,

TrainID_prime = {| t : TrainID :- t ~= t_none |},

TrainID == t1 | t2 | t_none,

SwitchboxID_prime = {| sb : SwitchboxID :- sb ~= sb_none |},

SwitchboxID == sb0 | sb1 | sb2 | sb3 | sb_none

value
route_t1 : array RouteIndex of SegmentID = {.s1, s2, s4, seg_none.},

route_t2 : array RouteIndex of SegmentID = {.s4, s3, s1, seg_none.},

switchboxes_t1 : array RouteIndex of SwitchboxID = {.sb1, sb2, sb3, sb_none.},

switchboxes_t2 : array RouteIndex of SwitchboxID = {.sb2, sb1, sb0, sb_none.},

sbSegments_sb0 : array SbIndex of SegmentID = {.s1, seg_none, seg_none.},

sbSegments_sb1 : array SbIndex of SegmentID = {.s1, s2, s3.},

sbSegments_sb2 : array SbIndex of SegmentID = {.s4, s2, s3.},

sbSegments_sb3 : array SbIndex of SegmentID = {.s4, seg_none, seg_none.}

transition_system [TS]
variable
hdPos_t1 : SegmentID,

hdPos_t2 : SegmentID,

tlPos_t1 : SegmentID,

tlPos_t2 : SegmentID,

nextSb_t1 : SwitchboxID,

nextSb_t2 : SwitchboxID,

index_t1 : RouteIndexFromOne,

index_t2 : RouteIndexFromOne,

tNextSbRes_t1 : array TwoIndex of SegmentID,

tNextSbRes_t2 : array TwoIndex of SegmentID,

tNextNextSbRes_t1 : SegmentID,

tNextNextSbRes_t2 : SegmentID,

tNextLocked_t1 : Bool,

tNextLocked_t2 : Bool,

sbSensor_sb0 : SensorState,

sbSensor_sb1 : SensorState,

sbSensor_sb2 : SensorState,

sbSensor_sb3 : SensorState,

sbConnection_sb0 : array TwoIndex of SegmentID,

sbConnection_sb1 : array TwoIndex of SegmentID,

sbConnection_sb2 : array TwoIndex of SegmentID,

sbConnection_sb3 : array TwoIndex of SegmentID,

sbReservations_sb0 : array SbIndex of TrainID,

sbReservations_sb1 : array SbIndex of TrainID,

sbReservations_sb2 : array SbIndex of TrainID,

sbReservations_sb3 : array SbIndex of TrainID,

sbLock_sb0 : TrainID,

sbLock_sb1 : TrainID,

sbLock_sb2 : TrainID,

sbLock_sb3 : TrainID,

reserveNextEvent : Bool,

reserveNextNextEvent : Bool,

switchLockEvent : Bool,

reqSeg : SegmentID,

reqConn : array TwoIndex of SegmentID,

req_t1 : SwitchboxID,

req_t2 : SwitchboxID,

ack_sb0 : TrainID,

ack_sb1 : TrainID,

ack_sb2 : TrainID,

ack_sb3 : TrainID,

nack_sb0 : TrainID,

nack_sb1 : TrainID,

nack_sb2 : TrainID,

nack_sb3 : TrainID

init_constraint
hdPos_t1 = s1,

tlPos_t1 = s1,

hdPos_t2 = s4,

tlPos_t2 = s4,

nextSb_t1 = sb1,

nextSb_t2 = sb2,

index_t1 = 1,

index_t2 = 1,

tNextSbRes_t1 = {.s1, seg_none.},

tNextSbRes_t2 = {.s4, seg_none.},

tNextNextSbRes_t1 = seg_none,

tNextNextSbRes_t2 = seg_none,

tNextLocked_t1 = false,

tNextLocked_t2 = false,

sbSensor_sb0 = passive,

sbSensor_sb1 = passive,

sbSensor_sb2 = passive,

sbSensor_sb3 = passive,

sbConnection_sb0 = {.s1, seg_none.},

sbConnection_sb1 = {.s1, s3.},

sbConnection_sb2 = {.s2, s4.},

sbConnection_sb3 = {.s4, seg_none.},

sbReservations_sb0 = {.t_none, t_none, t_none.},

sbReservations_sb1 = {.t1, t_none, t_none.},

sbReservations_sb2 = {.t2, t_none, t_none.},

sbReservations_sb3 = {.t_none, t_none, t_none.},

sbLock_sb0 = t_none,

sbLock_sb1 = t_none,

sbLock_sb2 = t_none,

sbLock_sb3 = t_none,

reserveNextEvent = false,

reserveNextNextEvent = false,

switchLockEvent = false,

reqSeg = seg_none,

reqConn = {.seg_none, seg_none.},

req_t1 = sb_none,

req_t2 = sb_none,

ack_sb0 = t_none,

ack_sb1 = t_none,

ack_sb2 = t_none,

ack_sb3 = t_none,

nack_sb0 = t_none,

nack_sb1 = t_none,

nack_sb2 = t_none,

nack_sb3 = t_none

